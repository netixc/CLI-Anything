#!/usr/bin/env python3
import asyncio
import json
import sys
import websockets

async def speak(text: str, host: str = "0.0.0.0", port: int = 12393):
    uri = f"ws://{host}:{port}/client-ws"
    try:
        async with websockets.connect(uri) as ws:
            await asyncio.sleep(1)
            await ws.send(json.dumps({"type": "direct-tts", "text": text}))
            await asyncio.sleep(2)
            return True
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        return False

if __name__ == "__main__":
    text = sys.argv[1] if len(sys.argv) > 1 else "Hello!"
    success = asyncio.run(speak(text))
    sys.exit(0 if success else 1)
